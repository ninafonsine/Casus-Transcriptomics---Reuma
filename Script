# KEGG analyse:

#Selecteer significante genen:
  res <- as.data.frame(resultaten)
  res <- res[!is.na(res$padj), ]

  # significante genen
    sig_genes <- rownames(res[res$padj < 0.05, ])
    
  #Gene symbols omzetten naar ENTREZ IDs
    entrez_ids <- mapIds(org.Hs.eg.db,
                         keys = sig_genes,
                         column = "ENTREZID",
                         keytype = "SYMBOL",  # pas dit aan indien nodig!
                         multiVals = "first")
    
    # verwijder NA's
    entrez_ids <- na.omit(entrez_ids)
    
#KEGG enrichment:
  BiocManager::install("clusterProfiler")
  library(clusterProfiler)


# KEGG gene-pathway mapping ophalen
kegg_data <- keggLink("pathway", "hsa")
  
kegg_df <- data.frame(
  pathway = sub("path:", "", kegg_data),
  gene = sub("hsa:", "", names(kegg_data))
)


# Overlap bepalen
common <- intersect(entrez_ids, kegg_df$gene)


# Enrichment uitvoeren
kegg_enrich <- enricher(
  gene = common,
  TERM2GENE = kegg_df,
  universe = kegg_df$gene)

  
# Bekijk resultaten
  head(as.data.frame(kegg_enrich))
  
  

# Descriptie toevoegen
  path_names <- keggList("pathway", "hsa")
  
  kegg_res <- as.data.frame(kegg_enrich)
  
  kegg_res$Description <- path_names[kegg_res$ID]
  
  head(kegg_res)

# Plot:
  kegg_res %>%
    head(10) %>%
    ggplot(aes(x = Count,
               y = Description,
               colour = p.adjust)) +
    geom_point(size = 4) +
    labs(x = "Aantal genen",
         y = "KEGG pathway",
         colour = "gecorrigeerde p-waarde")
  

