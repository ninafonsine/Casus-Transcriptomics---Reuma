# Bestandsnamen van de monsters
samples <- c('normaal1', 'normaal2', 'normaal3', 'normaal4', 'reuma1', 'reuma2',
             'reuma3', 'reuma4')

# Voor elk monster: sorteer en indexeer de BAM-file
## Sorteer BAM-bestanden
lapply(samples, function(s) {sortBam(file = paste0(s, '.BAM'), 
                                     destination = paste0(s, '.sorted'))
})

## Indexeer de gesorteerde BAM-file
lapply(samples, function(s) {indexBam(file = paste0(s, '.sorted.bam'))})

-------------------------------------------------------------------------------

#Count matrix opstellen
allsamples <- c("normaal1.BAM", "normaal2.BAM", "normaal3.BAM", "normaal4.BAM", 
                "reuma1.BAM", "reuma2.BAM", "reuma3.bam", "reuma4.bam")
count_matrix <- featureCounts(
  files = allsamples,
  annot.ext = "genomic.gtf",
  isPairedEnd = TRUE,
  isGTFAnnotationFile = TRUE,
  GTF.attrType = "gene_id",
  useMetaFeatures = TRUE
)

#Count matrix bekijken
str(count_matrix)


#Specifieke kolom pakken
counts <- count_matrix$counts
head(counts)

colnames(counts) <- c("gezond1", "gezond2", "gezond3", "gezond4", 
                      "reuma1", "reuma2", "reuma3", "reuma4")
head(counts)

#opslaan:

write.csv(counts, 'reuma_countmatrix.csv')



#Count matrix van Dewi inladen:

counts = count_matrix_RA

-------------------------------------------------------------------------------

#Metadata:
  ##Samplenaam linken met conditie
conditie <- c("gezond", "gezond", "gezond", "gezond", 
               "reuma", "reuma", "reuma", "reuma")
conditie_table <- data.frame(conditie)
rownames(conditie_table) <- c("SRR4785819", "SRR4785820", "SRR4785828", "SRR4785831", 
                                    "SRR4785979", "SRR4785980", "SRR4785986", "SRR4785988")

#Voor elk gen kijken: hoeveel expressie in RA en in een gezond persoon:
dds <- DESeqDataSetFromMatrix(countData = counts,
                              colData = conditie_table,
                              design = ~ conditie)

  # Voer analyse uit
dds <- DESeq(dds)
resultaten <- results(dds)

write.table(resultaten, file = 'ResultatenReuma.csv', row.names = TRUE, col.names = TRUE)

#Resultaten samenvatten
##Van hoeveel genen stijgt of daalt de expressie significant
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange > 1, na.rm = TRUE)   #2085
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange < -1, na.rm = TRUE)  #2487


#Volcano plot:
EnhancedVolcano(resultaten,
                lab = rownames(resultaten),
                x = 'log2FoldChange',
                y = 'padj')


--------------------------------------------------------------------------------    

# GO-analyse:


# Resultaten opslaan als dataframe
res <- as.data.frame(resultaten)

# Verwijder NA's
res <- res[!is.na(res$padj), ]



# Up- en downregulated genen apart definiĂ«ren
up_genes <- (res$log2FoldChange > 1) & (res$padj < 0.05)
down_genes <- (res$log2FoldChange < -1) & (res$padj < 0.05)

# Maak vectors voor goseq
up_vec <- as.integer(up_genes)
down_vec <- as.integer(down_genes)

names(up_vec) <- rownames(res)
names(down_vec) <- rownames(res)


#GO voor upregulated genen:
  ## Corrigeren op lengte voor GO-analyse met model organisme hg19:
  pwf_up <- nullp(up_vec,"hg19","geneSymbol")

  ## Voor elke GO-term kijken of er meer significante genen in deze categorie zijn
  ## dan verwacht
  GO_up <- goseq(pwf_up,"hg19","geneSymbol")

  ## Resultaten bekijken
  ### Corrigeren voor multiple testing
  GO_up$padj <- p.adjust(GO.up$over_represented_pvalue, method = "BH")

  sig_GO_up <- GO_up[GO_up$padj < 0.05, ]


  ## Plot maken
    ### 10 meest significante GO-termen kiezen
    ### Hoeveel % van de genen in die GO-termen zijn significant
    sig_GO_up %>% 
      top_n(10, wt = -padj) %>% 
      mutate(hitsPerc = numDEInCat * 100 / numInCat) %>% 
      ggplot(aes(x = hitsPerc, 
               y = reorder(term, hitsPerc), 
               colour = padj, 
               size = numDEInCat)) +
      geom_point() +
      scale_colour_gradient(low = "pink", high = "red") +
      expand_limits(x = 0) +
      labs(title = "GO enrichment (upregulated genen in RA)",
           x = "Percentage DE genen (%)", 
           y = "GO term (biologische processen", 
           colour = "Adjusted p-value", 
           size = "Aantal DE genen")
    
    
  #GO voor downregulated genen:
    ## Identiek aan GO voor upregulated, met enkele aanpassingen aan naamgeving
    pwf_down <- nullp(down_vec,"hg19","geneSymbol")
    
    GO_down <- goseq(pwf_down,"hg19","geneSymbol")
    
    GO_down$padj <- p.adjust(GO_down$over_represented_pvalue, method = "BH")
    
    sig_GO_down <- GO_down[GO_down$padj < 0.05, ]
    
    sig_GO_down %>% 
      top_n(10, wt = -padj) %>% 
      mutate(hitsPerc = numDEInCat * 100 / numInCat) %>% 
      ggplot(aes(x = hitsPerc, 
                 y = reorder(term, hitsPerc), 
                 colour = padj, 
                 size = numDEInCat)) +
      geom_point() +
      scale_color_gradient(low = "lightblue", high = "blue") +
      expand_limits(x = 0) +
      labs(title = "GO enrichment (downregulated genen in RA)",
           x = "Percentage DE genen (%)", 
           y = "GO term (biologische processen", 
           colour = "Adjusted p-value", 
           size = "Aantal DE genen")
    
  # Top 10 processen in een staafdiagram visualiseren
  library(GO.db)
  
  top10_GO_up <- GO_up %>%
    filter(padj < 0.05) %>%
    arrange(padj) %>%
    slice_head(n = 10)
  
  
  top10_GO_down <- GO_down %>%
    filter(padj < 0.05) %>%
    arrange(padj) %>%
    slice_head(n = 10)
  
  
  ## Data combineren
  ### Richting toevoegen
  top10_GO_up$direction <- "Upregulated"
  top10_GO_down$direction <- "Downregulated"
  
  ### Combineer datasets
  top10_GO_combined <- rbind(top10_GO_up, top10_GO_down)
  
  
  ## Plotten
  ggplot(top10_GO_combined,
         aes(x = reorder(term, -log10(padj)),
             y = -log10(padj),
             fill = direction)) +
    geom_bar(stat = "identity") +
    coord_flip() +
    facet_wrap(~ direction, scales = "free") +
    scale_fill_manual(values = c(
      "Upregulated" = "firebrick",
      "Downregulated" = "steelblue"
    )) +
    labs(
      title = "GO enrichment in RA",
      x = "GO-term",
      y = "-log10(adjusted p-value)"
    ) +
    theme_light()
  

--------------------------------------------------------------------------------
# KEGG analyse:

# Selecteer significante genen (DESeq2 resultaten voorbereiden)
res <- as.data.frame(resultaten)
res <- res[!is.na(res$padj), ]

# Upregulated genen
up_genes <- rownames(res[(res$log2FoldChange > 1) & (res$padj < 0.05), ])
    
# Downregulated genen
down_genes <- rownames(res[(res$log2FoldChange < -1) & (res$padj < 0.05), ])
    
# Gene symbols omzetten naar ENTREZ IDs
  ## Upregulated
  entrez_up <- mapIds(org.Hs.eg.db,
                         keys = up_genes,
                         column = "ENTREZID",
                         keytype = "SYMBOL",  # pas dit aan indien nodig!
                         multiVals = "first")
    
    ## verwijder NA's
    entrez_up <- na.omit(entrez_up)

  ## Downregulated
    entrez_down <- mapIds(org.Hs.eg.db,
                         keys = down_genes,
                         column = "ENTREZID",
                         keytype = "SYMBOL",  # pas dit aan indien nodig!
                         multiVals = "first")
    
    ## verwijder NA's
    entrez_down <- na.omit(entrez_down)
    
    


--------------------------------------------------------------------------------    
    
# KEGG enrichment:

  ## KEGG gene-pathway mapping ophalen
  kegg_data <- keggLink("pathway", "hsa")
  
  kegg_df <- data.frame(
    pathway = sub("path:", "", kegg_data),
    gene = sub("hsa:", "", names(kegg_data))
    )


# Overlap bepalen
  ## Upregulated
  common_up <- intersect(entrez_up, kegg_df$gene)

  ## Downregulated
  common_down <- intersect(entrez_down, kegg_df$gene)


# KEGG enrichment uitvoeren
  ## Upregulated
  kegg_up <- enricher(
    gene = common_up,
    TERM2GENE = kegg_df,
    universe = kegg_df$gene)
  
  ## Downregulated
  kegg_down <- enricher(
    gene = common_down,
    TERM2GENE = kegg_df,
    universe = kegg_df$gene)


# Resultaten netter maken
  ## Pathway namen ophalen
  path_names <- keggList("pathway", "hsa")
  
  ## Upregulated
  kegg_up_res <- as.data.frame(kegg_up)
  
  kegg_up_res$Description <- path_names[kegg_up_res$ID]
  
  ## Downregulated
  kegg_down_res <- as.data.frame(kegg_down)
  
  kegg_down_res$Description <- path_names[kegg_down_res$ID]
  
 
# Filteren op significantie
  ## Upregulated
  sig_kegg_up <- kegg_up_res[kegg_up_res$p.adjust < 0.05, ]
  
  ## Downregulated
  sig_kegg_down <- kegg_down_res[kegg_down_res$p.adjust < 0.05, ]
  
  
# Plotten:
  ## Upregulated
  sig_kegg_up %>%  
    top_n(10, wt = -p.adjust) %>%  
    ggplot(aes(x = Count,             
               y = reorder(Description, Count),             
               colour = p.adjust,             
               size = Count)) +  
    geom_point() +  
    scale_colour_gradient(low = "pink", high = "red") +  
    labs(    
      title = "KEGG pathways (upregulated genen in RA)",    
      x = "Aantal genen",    
      y = "Pathway",    
      colour = "Adjusted p-value",    
      size = "Aantal genen"  
      )
  
  ## Downregulated
  sig_kegg_down %>%  
    top_n(10, wt = -p.adjust) %>%  
    ggplot(aes(x = Count,             
               y = reorder(Description, Count),             
               colour = p.adjust,             
               size = Count)) +  
    geom_point() +  
    scale_colour_gradient(low = "lightblue", high = "blue") +  
    labs(    
      title = "KEGG pathways (downregulated genen in RA)",    
      x = "Aantal genen",    
      y = "Pathway",    
      colour = "Adjusted p-value",    
      size = "Aantal genen"  
    )
  
    ## Opslaan
    write.csv(sig_kegg_up, "KEGG_up.csv")
    write.csv(sig_kegg_down, "KEGG_down.csv")
  
--------------------------------------------------------------------------------
  
# Pathway visualisatie (pathview)
  
  ## Gene list maken
    gene_list <- res$log2FoldChange
    names(gene_list) <- rownames(res)
    
    # NA's verwijderen
    gene_list <- gene_list[!is.na(gene_list)]

      
  ## Pathway kiezen
    pathway.id = "hsa05323" #RA pathway

  
  ## Pathview   
    pathview(
      gene.data = gene_list,
      pathway.id = "hsa05323",
      species = "hsa",
      gene.idtype = "SYMBOL",
      limit = list(gene = 5),
      low = list(gene = "blue"),    # downregulated
      mid = list(gene = "white"),   # geen verschil
      high = list(gene = "red"),    # upregulated
      out.suffix = "RA_pathway"
    )
    

